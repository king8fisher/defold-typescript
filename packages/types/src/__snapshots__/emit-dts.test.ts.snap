   * \`\`\`
   */
  function vector4(): Vector4;
  /**
   * Creates a new vector with all components set to the
   * supplied scalar value.
   *
   * @param n - scalar value to splat
   * @returns new vector
   * @example
   * \`\`\`lua
   * local vec = vmath.vector4(1.0)
   * print(vec) --> vmath.vector4(1, 1, 1, 1)
