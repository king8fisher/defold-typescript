{
  "name": "@defold-ts/types",
  "version": "0.0.0",
  "description": "TypeScript types for the Defold engine's Lua APIs.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "regen": "bun scripts/regen.ts"
  }
}
