{
  "name": "@defold-typescript/types",
  "version": "0.0.0",
  "description": "TypeScript types for the Defold engine's Lua APIs.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/defold-typescript/toolchain.git",
    "directory": "packages/types"
  },
  "homepage": "https://github.com/defold-typescript/toolchain#readme",
  "bugs": "https://github.com/defold-typescript/toolchain/issues",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./src/index.ts"
    },
    "./script": {
      "types": "./generated/kinds/script.d.ts"
    },
    "./gui-script": {
      "types": "./generated/kinds/gui-script.d.ts"
    },
    "./render-script": {
      "types": "./generated/kinds/render-script.d.ts"
    },
    "./core-types": {
      "types": "./src/core-types.ts"
    },
    "./timers": {
      "types": "./src/timers.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "generated",
    "scripts",
    "api-targets.json",
    "index.d.ts",
    "!src/**/*.test.ts",
    "!scripts/**/*.test.ts",
    "!src/**/__snapshots__"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "regen": "bun scripts/regen.ts",
    "sync-api-docs": "bun scripts/sync-api-docs.ts",
    "ref-doc-delta": "bun scripts/ref-doc-delta.ts --target defold-1.9.8 --namespace label --present label.get_text --absent label.set_text"
  },
  "dependencies": {
    "lua-types": "^2.13.1"
  },
  "devDependencies": {
    "@typescript-to-lua/language-extensions": "1.19.0"
  }
}
