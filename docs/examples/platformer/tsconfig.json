{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@defold-typescript/types": ["../../../packages/types/src/index.ts"],
      "@defold-typescript/types/script": ["../../../packages/types/generated/kinds/script.d.ts"]
    },
    "typeRoots": [".defold-types"],
    "types": ["defold-1.12.4"]
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts"]
}
