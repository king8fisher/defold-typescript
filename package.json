{
  "name": "defold-typescript",
  "private": true,
  "version": "0.0.0",
  "description": "TypeScript to Lua transpiling for Defold — a faster, agent-friendly successor to ts-defold.",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "test": "bun test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "bun run --filter '*' typecheck",
    "smoke": "bun scripts/release-smoke.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@types/bun": "latest",
    "typescript": "6.0.2",
    "yaml": "^2.9.0"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
